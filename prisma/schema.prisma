generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password      String?
  role          Role      @default(USER)
  status        Status    @default(ACTIVE)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BannerGroup {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  active      Boolean  @default(true)
  duration    Int      @default(5000)
  width       Int      @default(1920)
  height      Int      @default(1080)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  playMode    String   @default("MANUAL")
  animation   String   @default("FADE")
  banners     Banner[]

  @@index([active])
  @@index([createdAt])
}

model Banner {
  id            Int          @id @default(autoincrement())
  title         String
  description   String?
  imageUrl      String
  linkUrl       String?
  active        Boolean      @default(true)
  order         Int
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  bannerGroupId Int
  bannerGroup   BannerGroup  @relation(fields: [bannerGroupId], references: [id], onDelete: Cascade)
  statistics    Statistics[]

  @@index([bannerGroupId])
  @@index([active])
  @@index([order])
  @@index([createdAt])
}

model Statistics {
  id        Int      @id @default(autoincrement())
  bannerId  Int
  type      String
  createdAt DateTime @default(now())
  banner    Banner   @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@index([bannerId])
  @@index([type])
  @@index([createdAt])
}

enum Role {
  ADMIN
  USER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PlayMode {
  MANUAL
  AUTO
}

enum AnimationType {
  FADE
  SLIDE
  ZOOM
}

enum ProjectStatus {
  PLANNING
  ONGOING
  COMPLETED
}

model Project {
  id             Int            @id @default(autoincrement())
  title          String
  description    String         @db.Text
  location       String
  features       Json?
  details        Json?
  status         ProjectStatus  @default(PLANNING)
  completionDate DateTime?
  isActive       Boolean        @default(true)
  coverImage     String?
  mainImage      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  images         ProjectImage[]
  videos         ProjectVideo[]

  @@index([isActive])
  @@index([status])
  @@index([createdAt])
}

model ProjectImage {
  id        Int      @id @default(autoincrement())
  url       String
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ProjectVideo {
  id        Int      @id @default(autoincrement())
  url       String
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Media {
  id           String   @id @default(cuid())
  url          String   @unique
  filename     String
  size         Int
  type         String   // "image" veya "video"
  mimeType     String?
  width        Int?
  height       Int?
  duration     Float?   // Video süresi (saniye)
  uploadedAt   DateTime @default(now())
  lastAccessed DateTime @default(now())
  isReferenced Boolean  @default(false)
  references   String[] // JSON formatında referans kayıtları
  
  @@index([type])
  @@index([isReferenced])
  @@index([uploadedAt])
}
